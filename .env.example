# --- Supabase (DB 저장 켜려면 둘 다 필수) ---
# 대시보드: Project Settings → API
# SUPABASE_URL = Project URL (https://xxxxx.supabase.co)  ← DB pooler 주소 아님
# SUPABASE_SERVICE_ROLE_KEY = service_role (secret) — 서버에만, 절대 프론트/깃에 노출 금지
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- 터미널 마이그레이션 (npm run db:migrate) 전용, 선택 ---
# Database → Connection string → URI (비밀번호 포함). API 키와 다릅니다.
# DATABASE_URL=postgresql://postgres.[ref]:[YOUR-DB-PASSWORD]@aws-0-....pooler.supabase.com:6543/postgres

# --- 선택 ---
# PORT=3002
# LISTEN_HOST=0.0.0.0
